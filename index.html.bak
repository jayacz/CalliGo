<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>书 Calli GO</title>
  
  <meta name="theme-color" content="#f0eaff">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <link id="appleTouchIcon" rel="apple-touch-icon" href="favicon.svg">

  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/hanzi-writer@3.5/dist/hanzi-writer.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Noto+Serif+SC:wght@400;700;900&family=Cormorant+Garamond:wght@400;600&display=swap" rel="stylesheet">
  
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; touch-action: manipulation; }
    
    html, body { 
      width: 100%; 
      height: 100dvh; 
      background-color: #f8f5ff; 
      overflow: hidden; 
    }
    
    body { 
      font-family: 'Cormorant Garamond', serif; 
      color: #8c6d4f;
      background-image: radial-gradient(circle at 20% 30%, rgba(225, 200, 255, 0.3) 0%, transparent 50%), radial-gradient(circle at 80% 70%, rgba(255, 215, 245, 0.3) 0%, transparent 50%);
      display: flex; flex-direction: column; align-items: center;
      padding: env(safe-area-inset-top) 15px env(safe-area-inset-bottom);
    }

    .w-total { width: 100%; max-width: 420px; } 
    .w-symbol { width: 100%; max-width: 350px; } 

    /* HEADER - PERFECT CENTERING WITH CHAR ON LEFT */
    .app-header { width: 100%; max-width: 420px; text-align: center; flex-shrink: 0; padding-top: 10px; }
    .header-group { 
      display: grid; 
      grid-template-columns: 1fr auto 1fr; /* Char | Title | Spacer */
      align-items: center; 
      width: 100%; 
      margin-bottom: -5px; 
    }
    .title-char { 
      font-family: 'Noto Serif SC', serif; 
      font-size: clamp(2.5rem, 10vw, 4.2rem); 
      color: #a67c52; 
      -webkit-text-stroke: 1.5px #000; 
      font-weight: 400; 
      line-height: 1; 
      justify-self: end;
      padding-right: 15px; 
    }
    .app-title-text { font-family: 'Dancing Script', cursive; color: #000; font-size: clamp(2.5rem, 10vw, 4.2rem); line-height: 1; }
    .title-spacer { width: 100%; } 
    
    .motto { font-size: clamp(1rem, 4.2vw, 1.5rem); font-weight: 800; text-align: center; text-decoration: underline; text-decoration-color: #000; text-underline-offset: 4px; text-decoration-thickness: 2px; margin-top: 2px; }

    /* NAVIGATION */
    nav { flex-shrink: 0; margin: 12px 0; width: 280px; display: flex; gap: 8px; }

    /* MAIN AREA */
    main { flex-grow: 1; width: 100%; position: relative; overflow: hidden; min-height: 0; }
    .view-container { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; }

    /* PRACTICE VIEW */
    #practiceView { height: 100%; justify-content: space-between; padding-bottom: 5px; overflow: hidden; }

    /* CALLIDEX VIEW (Scrollable) */
    #galleryView { height: 100%; overflow-y: auto; -webkit-overflow-scrolling: touch; padding: 10px 0 80px 0; display: flex; flex-direction: column; align-items: center; }
    #galleryView::-webkit-scrollbar { display: none; }

    /* CANVAS */
    .canvas-flex-box { flex-grow: 1; width: 100%; display: flex; align-items: center; justify-content: center; min-height: 0; padding: 5px 0; }
    .canvas-card { position: relative; aspect-ratio: 1/1; max-height: 100%; max-width: 100%; background-color: #f7ead0; border: 8px solid white; border-radius: 2.5rem; overflow: hidden; }
    #drawingCanvas { position: absolute; top: 0; left: 0; z-index: 10; touch-action: none; width: 100%; height: 100%; }
    #guideCanvas { position: absolute; top: 0; left: 0; z-index: 2; opacity: 0.6; pointer-events: none; width: 100%; height: 100%; }
    .paper-texture { background-image: url("https://www.transparenttextures.com/patterns/handmade-paper.png"); width: 100%; height: 100%; }

    #canvas-card.show-grid .paper-texture {
      background-image: url("https://www.transparenttextures.com/patterns/handmade-paper.png"),
        linear-gradient(to right, rgba(140,109,79,0.3) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(140,109,79,0.3) 1px, transparent 1px) !important;
      background-size: auto, 25% 25%, 25% 25% !important;
      background-position: center !important;
    }

    /* BUTTONS */
    .btn-base { transition: all 0.2s ease; font-weight: 900; text-transform: uppercase; display: flex; align-items: center; justify-content: center; border-radius: 1.5rem; cursor: pointer; }
    .btn-primary { background-color: #a67c52; color: white; border: 3px solid #a67c52; }
    .btn-secondary { background-color: white; color: #a67c52; border: 3px solid rgba(166, 124, 82, 0.3); }

    .footer-credit { flex-shrink: 0; padding: 5px 0; font-size: 0.9rem; opacity: 0.8; font-weight: 700; color: #8c6d4f; }
    .hidden { display: none !important; }

    /* STROKE ORDER MODAL */
    .stroke-modal { position: fixed; inset: 0; z-index: 100; display: flex; align-items: center; justify-content: center; }
    .stroke-modal-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.4); backdrop-filter: blur(4px); }
    .stroke-modal-content { position: relative; background: #f8f5ff; border-radius: 2.5rem; padding: 20px; width: 90%; max-width: 350px; display: flex; flex-direction: column; align-items: center; box-shadow: 0 20px 60px rgba(0,0,0,0.3); border: 4px solid white; }
    .stroke-modal-header { width: 100%; display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; padding: 0 4px; }
    .stroke-writer-box { width: 250px; height: 250px; background: #f7ead0; border: 6px solid white; border-radius: 1.5rem; overflow: hidden; display: flex; align-items: center; justify-content: center; }
    .stroke-writer-box svg { display: block; }
  </style>
</head>
<body>

    <header class="app-header">
      <div class="header-group">
        <span class="title-char">书</span>
        <h1 class="app-title-text">Calli GO</h1>
        <div class="title-spacer"></div>
      </div>
      <p class="motto">Gotta Write ’Em All!</p>
    </header>

    <nav>
      <button id="btnPractice" class="btn-base flex-1 py-2.5 text-lg btn-primary">Practice</button>
      <button id="btnGallery" class="btn-base flex-1 py-2.5 text-lg btn-secondary">Callidex</button>
    </nav>

    <main>
      <div id="practiceView" class="view-container">
        <!-- Symbol Card -->
        <div class="w-symbol flex items-center justify-between bg-white/70 backdrop-blur-xl p-3 rounded-[2rem] border border-white shadow-sm flex-shrink-0">
          <div class="flex items-center gap-6 pl-2">
            <div id="displayArea" class="text-5xl text-black font-normal" style="font-family:'Noto Serif SC',serif;">永</div>
            <div>
              <p id="charPinyin" class="text-lg font-bold text-[#a67c52] leading-tight">yǒng</p>
              <p id="charMeaning" class="text-lg italic text-black font-black leading-tight">forever</p>
            </div>
          </div>
          <button id="btnGenerate" class="btn-primary p-2.5 rounded-xl active:scale-90"><i data-lucide="refresh-cw" class="w-5 h-5"></i></button>
        </div>

        <!-- Canvas adaptive box -->
        <div class="canvas-flex-box w-total px-2">
            <div class="canvas-card shadow-lg" id="canvas-card">
              <canvas id="guideCanvas" class="paper-texture"></canvas>
              <canvas id="drawingCanvas"></canvas>
            </div>
        </div>

        <!-- Spodný Toolbar -->
        <div class="w-symbol flex flex-col gap-2 bg-white/30 p-3 rounded-[2rem] shadow-md flex-shrink-0">
          <div class="flex gap-2 w-full">
            <button id="btnStepBack" class="btn-base p-3 btn-secondary shrink-0"><i data-lucide="undo-2"></i></button>
            <button id="btnClearCanvas" class="btn-base flex-1 py-4 text-xl btn-secondary uppercase">Clear</button>
            <button id="btnStepForward" class="btn-base p-3 btn-secondary shrink-0"><i data-lucide="redo-2"></i></button>
          </div>
          <div class="flex gap-2 w-full">
            <button id="btnToggleGrid" class="btn-base flex-1 py-3 text-lg btn-secondary">Grid</button>
            <button id="btnToggleGuide" class="btn-base flex-1 py-3 text-lg btn-secondary">Trace</button>
            <button id="btnStrokes" class="btn-base flex-1 py-3 text-lg btn-secondary">Strokes</button>
          </div>
        </div>
      </div>

      <div id="galleryView" class="view-container hidden">
        <input type="text" id="searchBar" class="w-full max-w-[350px] p-3 mb-6 rounded-xl border-2 border-[#a67c52]/30 outline-none text-center text-xl shadow-sm flex-shrink-0" placeholder="Search by meaning...">
        <div id="galleryGrid" class="w-full grid grid-cols-2 gap-4 px-2"></div>
      </div>
    </main>

    <!-- Stroke Order Modal -->
    <div id="strokeModal" class="stroke-modal hidden">
      <div class="stroke-modal-backdrop"></div>
      <div class="stroke-modal-content">
        <div class="stroke-modal-header">
          <span id="strokeModalChar" class="text-3xl font-bold" style="font-family:'Noto Serif SC',serif;">永</span>
          <span class="text-lg text-[#a67c52] font-bold">Stroke Order</span>
          <button id="btnCloseStrokes" class="btn-base p-2 btn-secondary rounded-xl"><i data-lucide="x" class="w-5 h-5"></i></button>
        </div>
        <div id="strokeWriterTarget" class="stroke-writer-box"></div>
        <div class="flex gap-2 w-full mt-3">
          <button id="btnAnimateStrokes" class="btn-base flex-1 py-3 text-lg btn-primary">Animate</button>
        </div>
      </div>
    </div>

    <footer class="footer-credit">Vibe coded for Adel by Jaya 🫰</footer>

  <script>
  // --- DATABASE (loaded dynamically from Make Me a Hanzi) ---
  const FALLBACK_CHARS = [
