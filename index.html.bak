    { char:'钉', pinyin:'dīng', meaning:'nail' },
    { char:'钻', pinyin:'zuàn', meaning:'drill / diamond' },
    { char:'凿', pinyin:'záo', meaning:'chisel' },
    { char:'锹', pinyin:'qiāo', meaning:'shovel' },
    { char:'镰', pinyin:'lián', meaning:'sickle' },
    { char:'耙', pinyin:'pá', meaning:'rake' },
    { char:'厨', pinyin:'chú', meaning:'kitchen' },
    { char:'浴', pinyin:'yú', meaning:'bath' },
    { char:'厕', pinyin:'cè', meaning:'toilet' },
    { char:'具', pinyin:'jù', meaning:'tool / utensil' },
    { char:'皿', pinyin:'mǐn', meaning:'vessel / dish' },
    { char:'盆', pinyin:'pén', meaning:'basin / pot' },
    { char:'罐', pinyin:'guàn', meaning:'jar / tin' },
    { char:'盒', pinyin:'hé', meaning:'box / case' },
    { char:'笼', pinyin:'lóng', meaning:'cage / basket' },
    { char:'席', pinyin:'xí', meaning:'mat / seat' },
    { char:'帘', pinyin:'lián', meaning:'curtain' },
    { char:'罩', pinyin:'zhào', meaning:'cover / shade' },
    { char:'锦', pinyin:'jǐn', meaning:'brocade / bright' },
    { char:'绣', pinyin:'xiù', meaning:'embroidery' },
    { char:'纹', pinyin:'wén', meaning:'pattern / ripple' },
    { char:'饰', pinyin:'shì', meaning:'decorate' },
    { char:'装', pinyin:'zhuāng', meaning:'dress / pack' },
    { char:'束', pinyin:'shù', meaning:'bundle / bind' },
    { char:'缠', pinyin:'chán', meaning:'wrap / wind' },
    { char:'绕', pinyin:'rào', meaning:'revolve / wind' },
    { char:'织', pinyin:'zhī', meaning:'weave' },
    { char:'缝', pinyin:'féng', meaning:'sew / stitch' },
    { char:'染', pinyin:'rǎn', meaning:'dye / catch' },
    { char:'烫', pinyin:'tàng', meaning:'scald / iron' },
    { char:'剪', pinyin:'jiǎn', meaning:'cut / scissors' },
    { char:'裁', pinyin:'cái', meaning:'cut (cloth) / judge' },
    { char:'贴', pinyin:'tiē', meaning:'paste / stick' },
    { char:'扣', pinyin:'kòu', meaning:'button / discount' },
    { char:'纽', pinyin:'niǔ', meaning:'button / link' },
    { char:'缎', pinyin:'duàn', meaning:'satin' },
    { char:'绒', pinyin:'róng', meaning:'velvet / wool' },
    { char:'纱', pinyin:'shā', meaning:'yarn / gauze' },
    { char:'婚', pinyin:'hūn', meaning:'marriage' },
    { char:'嫁', pinyin:'jià', meaning:'marry (woman)' },
    { char:'娶', pinyin:'qǔ', meaning:'marry (man)' },
    { char:'孕', pinyin:'yùn', meaning:'pregnant' },
    { char:'养', pinyin:'yǎng', meaning:'raise / nourish' },
    { char:'僚', pinyin:'liáo', meaning:'colleague' },
    { char:'戚', pinyin:'qī', meaning:'relative / grief' },
    { char:'侣', pinyin:'lǚ', meaning:'companion' },
    { char:'怨', pinyin:'yuàn', meaning:'resentment' },
    { char:'恕', pinyin:'shù', meaning:'forgive' },
    { char:'宠', pinyin:'chǒng', meaning:'pamper / spoil' },
    { char:'怜', pinyin:'lián', meaning:'pity / love' },
    { char:'惜', pinyin:'xī', meaning:'cherish / pity' },
    { char:'敬', pinyin:'jìng', meaning:'respect' },
    { char:'畏', pinyin:'wèi', meaning:'fear / awe' },
    { char:'慕', pinyin:'mù', meaning:'admire' },
    { char:'嫉', pinyin:'jí', meaning:'jealous' },
    { char:'妒', pinyin:'dù', meaning:'envy' },
    { char:'好', pinyin:'hǎo', meaning:'good' },
    { char:'大', pinyin:'dà', meaning:'big' },
    { char:'小', pinyin:'xiǎo', meaning:'small' },
    { char:'书', pinyin:'shū', meaning:'book' },
    { char:'爱', pinyin:'ài', meaning:'love' },
    { char:'心', pinyin:'xīn', meaning:'heart' },
    { char:'龙', pinyin:'lóng', meaning:'dragon' },
    { char:'山', pinyin:'shān', meaning:'mountain' },
    { char:'水', pinyin:'shuǐ', meaning:'water' },
    { char:'火', pinyin:'huǒ', meaning:'fire' }
  ];

  let characters = [...FALLBACK_CHARS];
  let dbLoaded = false;

  // Load full database from Make Me a Hanzi (CDN)
  async function loadHanziDatabase() {
    try {
      const res = await fetch('https://cdn.jsdelivr.net/gh/skishore/makemeahanzi@master/dictionary.txt');
      if (!res.ok) throw new Error('fetch failed');
      const text = await res.text();
      const lines = text.trim().split('\n');
      const parsed = [];
      for (const line of lines) {
        try {
          const entry = JSON.parse(line);
          // Only single characters with pinyin and definition
          if (entry.character && entry.character.length === 1 && entry.pinyin && entry.pinyin.length > 0 && entry.definition) {
            parsed.push({
              char: entry.character,
              pinyin: entry.pinyin[0],
              meaning: entry.definition.split(',')[0].split(';')[0].trim()
            });
          }
        } catch(e) { /* skip malformed lines */ }
      }
      if (parsed.length > 100) {
        characters = parsed;
        dbLoaded = true;
        console.log(`Loaded ${characters.length} characters from Hanzi database`);
      }
    } catch(e) {
      console.warn('Could not load Hanzi database, using fallback:', e.message);
    }
  }

  loadHanziDatabase();

  let currentChar = { char:'永', pinyin:'yǒng', meaning:'forever' };
  let isTraceActive = false;

  const setupCanvas = () => {
    const canvas = document.getElementById('drawingCanvas');
    const gCanvas = document.getElementById('guideCanvas');
    const ctx = canvas.getContext('2d');
    const gCtx = gCanvas.getContext('2d');
    let isDrawing = false, strokes = [], currentStroke = [], redoStack = [];
    let lastX, lastY, lastW, lastTime;

    const resize = () => {
      const flexBox = canvas.parentElement.parentElement;
      const dpr = window.devicePixelRatio || 1;
      const size = Math.min(flexBox.clientWidth, flexBox.clientHeight);
      const card = canvas.parentElement;
      card.style.width = size + 'px'; card.style.height = size + 'px';
      canvas.width = size * dpr; canvas.height = size * dpr;
      gCanvas.width = size * dpr; gCanvas.height = size * dpr;
      canvas.style.width = size + 'px'; canvas.style.height = size + 'px';
      ctx.scale(dpr, dpr); gCtx.scale(dpr, dpr);
      redraw();
    };

    const redraw = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#000';
      strokes.forEach(s => drawPath(s));
      drawGuide();
    };

    const drawPath = (pts) => {
      if (pts.length < 2) return;
      for (let i = 1; i < pts.length; i++) {
        const p1 = pts[i-1], p2 = pts[i];
        const dist = Math.hypot(p2.x - p1.x, p2.y - p1.y);
        const steps = Math.ceil(dist * 2.5);
        for (let s = 0; s <= steps; s++) {
          const t = s / steps;
          const x = p1.x + (p2.x - p1.x) * t;
          const y = p1.y + (p2.y - p1.y) * t;
          const w = (p1.w + (p2.w - p1.w) * t);
          ctx.beginPath(); ctx.arc(x, y, w / 2, 0, Math.PI * 2); ctx.fill();
        }
      }
    };

    const drawGuide = async () => {
      gCtx.clearRect(0, 0, gCanvas.width, gCanvas.height);
      if (!isTraceActive) return;
      await document.fonts.load('400 48px "Noto Serif SC"', currentChar.char);
      const s = gCanvas.width / (window.devicePixelRatio || 1);
      gCtx.font = `400 ${s * 0.72}px "Noto Serif SC"`;
      gCtx.fillStyle = 'rgba(0,0,0,0.4)';
      gCtx.textAlign = 'center'; gCtx.textBaseline = 'middle';
      gCtx.fillText(currentChar.char, s/2, s/2);
    };

    const getPos = (e) => {
      const r = canvas.getBoundingClientRect();
      const cx = (e.touches ? e.touches[0].clientX : e.clientX);
      const cy = (e.touches ? e.touches[0].clientY : e.clientY);
      return { x: cx - r.left, y: cy - r.top, t: Date.now() };
    };

    canvas.addEventListener('pointerdown', (e) => {
      isDrawing = true; const p = getPos(e);
      lastX = p.x; lastY = p.y; lastTime = p.t; lastW = 16;
      currentStroke = [{ x: p.x, y: p.y, w: lastW }];
      ctx.fillStyle = '#000';
      ctx.beginPath(); ctx.arc(p.x, p.y, lastW/2, 0, Math.PI*2); ctx.fill();
    });

    canvas.addEventListener('pointermove', (e) => {
      if (!isDrawing) return;
      const p = getPos(e); const d = Math.hypot(p.x - lastX, p.y - lastY);
      const v = (p.t - lastTime) > 0 ? d / (p.t - lastTime) : 0;
      let targetW = Math.max(3, 16 - (v * 5)); 
      const cw = lastW * 0.3 + targetW * 0.7;
      const pPrev = currentStroke[currentStroke.length - 1], pNew = { x: p.x, y: p.y, w: cw };
      drawPath([pPrev, pNew]);
      currentStroke.push(pNew);
      lastX = p.x; lastY = p.y; lastTime = p.t; lastW = cw;
    });

    canvas.addEventListener('pointerup', () => { if (isDrawing) strokes.push([...currentStroke]); isDrawing = false; });
    window.addEventListener('resize', resize);
    document.getElementById('btnClearCanvas').onclick = () => { strokes = []; redraw(); };
    document.getElementById('btnStepBack').onclick = () => { if(strokes.length > 0) { redoStack.push(strokes.pop()); redraw(); } };
    document.getElementById('btnStepForward').onclick = () => { if(redoStack.length > 0) { strokes.push(redoStack.pop()); redraw(); } };
    
    document.getElementById('btnToggleGrid').onclick = (e) => {
      const isOn = document.getElementById('canvas-card').classList.toggle('show-grid');
      e.target.classList.replace(isOn ? 'btn-secondary' : 'btn-primary', isOn ? 'btn-primary' : 'btn-secondary');
    };

    document.getElementById('btnToggleGuide').onclick = (e) => { 
      isTraceActive = !isTraceActive;
      e.target.classList.replace(isTraceActive ? 'btn-secondary' : 'btn-primary', isTraceActive ? 'btn-primary' : 'btn-secondary');
      drawGuide(); 
    };

    setTimeout(resize, 100);
    return { clear: () => { strokes = []; redraw(); }, drawGuide };
  };

  const canvasCtrl = setupCanvas();

  const renderGallery = (filterText = "") => {
    const grid = document.getElementById('galleryGrid');
    grid.innerHTML = '';
    let list = (filterText.trim() === "") ? [...characters].sort(() => 0.5 - Math.random()).slice(0, 8) : characters.filter(i => i.meaning.toLowerCase().startsWith(filterText.toLowerCase())).slice(0, 50);
    list.forEach(item => {
      const div = document.createElement('div');
      div.className = 'bg-white/70 p-8 rounded-[2.5rem] flex flex-col items-center justify-center cursor-pointer transition-all active:scale-95 shadow-sm';
      div.innerHTML = `<div class="text-7xl mb-4 text-black font-normal" style="font-family:'Noto Serif SC'">${item.char}</div><div class="text-2xl uppercase font-bold text-[#a67c52]">${item.pinyin}</div><div class="text-2xl italic text-black font-black text-center">${item.meaning}</div>`;
      div.onclick = () => {
        currentChar = item;
        document.getElementById('displayArea').innerText = item.char;
        document.getElementById('charPinyin').innerText = item.pinyin;
        document.getElementById('charMeaning').innerText = item.meaning;
        canvasCtrl.clear(); canvasCtrl.drawGuide();
        document.getElementById('btnPractice').click();
      };
      grid.appendChild(div);
    });
  };

  document.getElementById('searchBar').oninput = (e) => renderGallery(e.target.value);
  document.getElementById('btnGallery').onclick = () => {
    document.getElementById('galleryView').classList.remove('hidden');
    document.getElementById('practiceView').classList.add('hidden');
    document.getElementById('btnGallery').classList.replace('btn-secondary', 'btn-primary');
    document.getElementById('btnPractice').classList.replace('btn-primary', 'btn-secondary');
    renderGallery();
  };
  document.getElementById('btnPractice').onclick = () => {
    document.getElementById('practiceView').classList.remove('hidden');
    document.getElementById('galleryView').classList.add('hidden');
    document.getElementById('btnPractice').classList.replace('btn-secondary', 'btn-primary');
    document.getElementById('btnGallery').classList.replace('btn-primary', 'btn-secondary');
  };
  document.getElementById('btnGenerate').onclick = () => {
    currentChar = characters[Math.floor(Math.random()*characters.length)];
    document.getElementById('displayArea').innerText = currentChar.char;
    document.getElementById('charPinyin').innerText = currentChar.pinyin;
    document.getElementById('charMeaning').innerText = currentChar.meaning;
    canvasCtrl.clear(); canvasCtrl.drawGuide();
  };

  // --- STROKE ORDER MODAL ---
  let hwWriter = null;
  const strokeModal = document.getElementById('strokeModal');
  const strokeTarget = document.getElementById('strokeWriterTarget');

  document.getElementById('btnStrokes').onclick = () => {
    // Clear previous writer
    strokeTarget.innerHTML = '';
    document.getElementById('strokeModalChar').innerText = currentChar.char;

    // Create new HanziWriter instance
    hwWriter = HanziWriter.create(strokeTarget, currentChar.char, {
      width: 238,
      height: 238,
      padding: 10,
      showOutline: true,
      showCharacter: false,
      strokeColor: '#000',
      outlineColor: '#ddd',
      strokeAnimationSpeed: 1,
      delayBetweenStrokes: 300,
    });

    strokeModal.classList.remove('hidden');

    // Auto-animate on open
    setTimeout(() => hwWriter.animateCharacter(), 200);
  };

  document.getElementById('btnAnimateStrokes').onclick = () => {
    if (hwWriter) {
      hwWriter.hideCharacter();
      hwWriter.animateCharacter();
    }
  };

  document.getElementById('btnCloseStrokes').onclick = () => {
    strokeModal.classList.add('hidden');
    strokeTarget.innerHTML = '';
    hwWriter = null;
  };

  // Close on backdrop click
  document.querySelector('.stroke-modal-backdrop').onclick = () => {
    document.getElementById('btnCloseStrokes').click();
  };

  lucide.createIcons();

  // Generate apple-touch-icon PNG from canvas once font is loaded
  document.fonts.load('900 48px "Noto Serif SC"', '书').then(() => {
    const s = 180;
    const c = document.createElement('canvas');
    c.width = s; c.height = s;
    const x = c.getContext('2d');
    x.fillStyle = '#f0eaff';
    x.beginPath(); x.roundRect(0, 0, s, s, 32); x.fill();
    x.font = '900 140px "Noto Serif SC"';
    x.fillStyle = '#a67c52';
    x.textAlign = 'center'; x.textBaseline = 'middle';
    x.fillText('书', s/2, s/2 + 6);
    const link = document.getElementById('appleTouchIcon');
    link.href = c.toDataURL('image/png');
  });
  </script>
</body>
</html>
